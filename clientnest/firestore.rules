rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /timelogs/{docId} {
      // For read (both single doc and list queries where userId == currentUserId)
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      // For creating a new log, we check request.resource instead of resource
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      // For update/delete, we check the existing resource
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    match /clients/{docId} {
      allow read, write: if request.auth != null;
    }

    match /projects/{docId} {
      allow read, write: if request.auth != null;

      match /tasks/{taskId} {
        allow read, write: if request.auth != null;
      }
    }

    // Flat tasks collection (in case the app uses it directly)
    match /tasks/{taskId} {
      allow read, write: if request.auth != null;
    }

    match /invoices/{docId} {
      allow read, write: if request.auth != null;
    }
    
    match /users/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == docId;
    }
  }
}
